{
  "name": "todoist-weekly-review-mcp",
  "version": "0.2.0",
  "description": "Thin MCP server for a Todoist weekly review: reads overdue tasks and applies human-approved fixes.",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "todoist-weekly-review-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "start": "node --env-file-if-exists=.env dist/index.js",
    "test": "npm run build && node --test dist/*.test.js",
    "bundle": "esbuild src/index.ts --bundle --platform=node --target=node18 --format=cjs --outfile=plugin/server.cjs",
    "build:plugin": "npm run bundle",
    "prepublishOnly": "npm test"
  },
  "keywords": [
    "mcp",
    "todoist"
  ],
  "author": "Yug Marwaha",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/yugmarwaha/todoist-weekly-review-mcp.git"
  },
  "files": [
    "dist",
    "!dist/*.test.js",
    "!dist/*.test.d.ts"
  ],
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "esbuild": "^0.28.1",
    "typescript": "^5.5.0"
  }
}
